# Public HTTPS origin used by Claude / ChatGPT to connect to the MCP endpoint.
PUBLIC_BASE_URL=https://reel.example.com
PORT=3000

# Streamable HTTP MCP route. /mcp is always kept as an alias for local smoke tests.
MCP_HTTP_PATH=/mcp/reel

# CORS allowlist (comma separated). Defaults to the PUBLIC_BASE_URL origin.
ALLOWED_ORIGINS=https://reel.example.com

# Optional OAuth password gate for remote connectors.
# Leave empty to disable auth; set a password to enable Authorization Code auth.
MCP_AUTH_PASSWORD=
